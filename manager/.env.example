# ===========================================
# Manager Service - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
HOST=localhost

# Environment
NODE_ENV=development

# ===========================================
# Security
# ===========================================
# API Keys for authenticating requests
API_KEYS=

# Internal service token for service-to-service communication
INTERNAL_SERVICE_TOKEN=

# ===========================================
# Connected Services URLs
# ===========================================
BACKGROUND_ENGINE_URL=http://localhost:3001
POST_GENERATOR_URL=http://localhost:3002
AUTO_POSTER_URL=http://localhost:3003

# ===========================================
# Database
# ===========================================
# DATABASE_URL=sqlite:./data/manager.db

# ===========================================
# File Upload
# ===========================================
MAX_FILE_SIZE=50mb
UPLOAD_PATH=./uploads

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
