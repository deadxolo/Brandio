# ===========================================
# Social Media Manager - Root Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env files with real credentials!

# ===========================================
# Environment
# ===========================================
NODE_ENV=development
# Set to 'production' in production environment

# ===========================================
# Security - REQUIRED IN PRODUCTION
# ===========================================
# API Keys for authenticating requests (comma-separated for multiple keys)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEYS=

# JWT Secret for token signing
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Internal service-to-service token
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
INTERNAL_SERVICE_TOKEN=

# Token encryption key (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ===========================================
# AI Services
# ===========================================
# Gemini API Key - Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# ===========================================
# OAuth - Social Media Platforms
# ===========================================
# Meta (Facebook/Instagram)
# Create app at: https://developers.facebook.com/
META_APP_ID=
META_APP_SECRET=

# Twitter/X
# Create app at: https://developer.twitter.com/
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# LinkedIn
# Create app at: https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ===========================================
# Service URLs (for production deployment)
# ===========================================
MANAGER_URL=http://localhost:3000
BACKGROUND_ENGINE_URL=http://localhost:3001
POST_GENERATOR_URL=http://localhost:3002
AUTO_POSTER_URL=http://localhost:3003

# OAuth callback base URL (your domain in production)
OAUTH_CALLBACK_BASE_URL=http://localhost:3003
