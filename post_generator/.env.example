# ===========================================
# Post Generator Service - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3002
HOST=localhost

# Environment
NODE_ENV=development

# ===========================================
# Security
# ===========================================
# API Keys for authenticating requests
API_KEYS=

# Internal service token
INTERNAL_SERVICE_TOKEN=

# ===========================================
# Connected Services URLs
# ===========================================
BACKGROUND_ENGINE_URL=http://localhost:3001
MANAGER_URL=http://localhost:3000

# ===========================================
# AI Services (Optional - for AI-powered features)
# ===========================================
GEMINI_API_KEY=

# ===========================================
# File Storage
# ===========================================
UPLOAD_PATH=./uploads
EXPORT_PATH=./uploads/exports
MAX_FILE_SIZE=50mb

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
