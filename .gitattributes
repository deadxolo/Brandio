# Normalize line endings across the repo
* text=auto eol=lf

# Shell scripts always LF
*.sh text eol=lf

# Windows batch / PowerShell stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Mark binaries explicitly so Git doesn't try to normalize them
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.gz binary

# Don't show diffs for package-lock.json
package-lock.json -diff
