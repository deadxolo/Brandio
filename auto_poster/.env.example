# ===========================================
# Auto Poster Service - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3003
HOST=localhost

# Environment
NODE_ENV=development

# ===========================================
# Security - REQUIRED IN PRODUCTION
# ===========================================
# Token encryption key (minimum 32 characters) - REQUIRED
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# API Keys for authenticating requests
API_KEYS=

# Internal service token
INTERNAL_SERVICE_TOKEN=

# ===========================================
# OAuth - Meta (Facebook/Instagram)
# ===========================================
# Create app at: https://developers.facebook.com/
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3003/api/oauth/meta/callback

# ===========================================
# OAuth - Twitter/X
# ===========================================
# Create app at: https://developer.twitter.com/
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:3003/api/oauth/twitter/callback

# ===========================================
# OAuth - LinkedIn
# ===========================================
# Create app at: https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3003/api/oauth/linkedin/callback

# ===========================================
# Database
# ===========================================
# DATABASE_URL=sqlite:./data/auto_poster.db

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
